# --- Provider selection (auto = OpenAI if key, else Gemini, else local) ---
LLM_PROVIDER=auto
EMBEDDING_PROVIDER=auto

# --- Keys (set at least one) ---
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Models (sensible defaults; override if needed) ---
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
LOCAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Retrieval / chunking ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4
INDEX_DIR=index
